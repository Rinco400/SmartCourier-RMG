# Copy this file to .env or set these variables in your terminal before running the project.
# The current settings.py reads from OS environment variables.

DJANGO_SECRET_KEY=replace-with-your-own-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Optional payment and map settings
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
GOOGLE_MAPS_API_KEY=

# Optional PostgreSQL configuration
# Leave DB_ENGINE empty to use SQLite locally.
DB_ENGINE=
DB_NAME=rmgdelivery
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
